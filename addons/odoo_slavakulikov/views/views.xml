<odoo>
    <record id="view_order_form_inherit_odoo_slavakulikov" model="ir.ui.view">
        <field name="name">sale.order.form.odoo.slavakulikov</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='payment_term_id']" position="after">
                <field name="responsible_employee_id" required="True"/>
                <field name="new_field"
                       readonly="state == 'sent'"
                       invisible="state == 'sale'"/>
            </xpath>
        </field>
    </record>
</odoo>